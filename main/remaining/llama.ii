// models/nova_llama.cpp
#include "llama.h"
#include <cmath>
#include <cstring>
#include <algorithm>
#include <fstream>

namespace nova {

LLaMAModel::LLaMAModel() {}

LLaMAModel::LLaMAModel(const LLaMAConfig& config) {
    init(config);
}

LLaMAModel::~LLaMAModel() {}

void LLaMAModel::init(const LLaMAConfig& config) {
    config_ = config;

    size_t hidden = config_.hidden_size;
    size_t intermediate = config_.intermediate_size;
    size_t vocab = config_.vocab_size;
    size_t layers = config_.num_layers;
    size_t q_size = config_.num_heads * config_.head_dim;
    size_t kv_size = config_.num_kv_heads * config_.head_dim;

    embed_table_.resize(vocab * hidden);
    final_norm_.resize(hidden);
    lm_head_.resize(hidden * vocab);

    layers_.resize(layers);
    for (size_t i = 0; i < layers; i++) {
        auto& layer = layers_[i];
        layer.attn_q_weight.resize(hidden * q_size);
        layer.attn_k_weight.resize(hidden * kv_size);
        layer.attn_v_weight.resize(hidden * kv_size);
        layer.attn_o_weight.resize(q_size * hidden);
        layer.mlp_gate_weight.resize(hidden * intermediate);
        layer.mlp_up_weight.resize(hidden * intermediate);
        layer.mlp_down_weight.resize(intermediate * hidden);
        layer.attn_norm_weight.resize(hidden);
        layer.mlp_norm_weight.resize(hidden);
    }

    activations_.resize(hidden * 4);
    gradients_.resize(hidden * 4);
}

void LLaMAModel::forward(const float* input, float* output, size_t batch, size_t seq_len) {
    size_t hidden = config_.hidden_size;
    size_t vocab = config_.vocab_size;
    size_t layers = config_.num_layers;

    std::vector<float> x(batch * seq_len * hidden);
    std::vector<float> residual(batch * seq_len * hidden);
    std::vector<float> norm_out(batch * seq_len * hidden);

    // Embedding
    for (size_t i = 0; i < batch * seq_len; i++) {
        int token = static_cast<int>(input[i]);
        const float* embed = embed_table_.data() + token * hidden;
        memcpy(x.data() + i * hidden, embed, hidden * sizeof(float));
    }

    // Layers
    for (size_t l = 0; l < layers; l++) {
        const auto& layer = layers_[l];

        // RMSNorm
        rms_norm(x.data(), norm_out.data(), layer.attn_norm_weight.data(),
                 batch * seq_len * hidden, config_.rms_norm_eps);

        // Attention (simplified)
        attention(norm_out.data(), norm_out.data(), norm_out.data(),
                  residual.data(), batch, seq_len,
                  config_.num_heads, config_.head_dim, true);

        // Add residual
        for (size_t i = 0; i < batch * seq_len * hidden; i++) {
            residual.data()[i] += x.data()[i];
        }

        // RMSNorm
        rms_norm(residual.data(), norm_out.data(), layer.mlp_norm_weight.data(),
                 batch * seq_len * hidden, config_.rms_norm_eps);

        // MLP
        swiglu_mlp(norm_out.data(), x.data(),
                   layer.mlp_gate_weight.data(),
                   layer.mlp_up_weight.data(),
                   layer.mlp_down_weight.data(),
                   hidden, config_.intermediate_size);

        // Add residual
        for (size_t i = 0; i < batch * seq_len * hidden; i++) {
            x.data()[i] += residual.data()[i];
        }
    }

    // Final RMSNorm
    rms_norm(x.data(), norm_out.data(), final_norm_.data(),
             batch * seq_len * hidden, config_.rms_norm_eps);

    // LM Head
    for (size_t i = 0; i < batch * seq_len; i++) {
        const float* norm_in = norm_out.data() + i * hidden;
        float* logits = output + i * vocab;

        for (size_t v = 0; v < vocab; v++) {
            float sum = 0.0f;
            const float* head = lm_head_.data() + v * hidden;
            for (size_t j = 0; j < hidden; j++) {
                sum += norm_in[j] * head[j];
            }
            logits[v] = sum;
        }
    }
}

void LLaMAModel::rms_norm(const float* input, float* output, const float* weight,
                          size_t size, float eps) {
    size_t rows = size / config_.hidden_size;
    size_t cols = config_.hidden_size;

    for (size_t i = 0; i < rows; i++) {
        const float* in = input + i * cols;
        float* out = output + i * cols;

        float sum = 0.0f;
        for (size_t j = 0; j < cols; j++) {
            sum += in[j] * in[j];
        }

        float rms = 1.0f / sqrtf(sum / cols + eps);

        for (size_t j = 0; j < cols; j++) {
            out[j] = in[j] * rms * weight[j];
        }
    }
}

void LLaMAModel::swiglu_mlp(const float* input, float* output,
                            const float* gate, const float* up, const float* down,
                            size_t hidden, size_t intermediate) {
    std::vector<float> temp(intermediate);

    for (size_t i = 0; i < hidden; i++) {
        const float* in = input + i * hidden;
        float* out = output + i * hidden;

        // Gate
        for (size_t j = 0; j < intermediate; j++) {
            float sum = 0.0f;
            for (size_t k = 0; k < hidden; k++) {
                sum += in[k] * gate[j * hidden + k];
            }
            temp[j] = sum;
        }

        // Swish
        for (size_t j = 0; j < intermediate; j++) {
            temp[j] = temp[j] / (1.0f + expf(-temp[j]));
        }

        // Up
        for (size_t j = 0; j < intermediate; j++) {
            float sum = 0.0f;
            for (size_t k = 0; k < hidden; k++) {
                sum += in[k] * up[j * hidden + k];
            }
            temp[j] *= sum;
        }

        // Down
        for (size_t j = 0; j < hidden; j++) {
            float sum = 0.0f;
            for (size_t k = 0; k < intermediate; k++) {
                sum += temp[k] * down[j * intermediate + k];
            }
            out[j] = sum;
        }
    }
}

void LLaMAModel::attention(const float* q, const float* k, const float* v, float* output,
                           size_t batch, size_t seq_len, size_t num_heads,
                           size_t head_dim, bool causal) {
    size_t total_heads = batch * num_heads;
    size_t head_size = seq_len * head_dim;

    for (size_t h = 0; h < total_heads; h++) {
        const float* q_head = q + h * head_size;
        const float* k_head = k + h * head_size;
        const float* v_head = v + h * head_size;
        float* o_head = output + h * head_size;

        // Attention scores
        std::vector<float> scores(seq_len * seq_len);

        for (size_t i = 0; i < seq_len; i++) {
            const float* q_i = q_head + i * head_dim;

            for (size_t j = 0; j < seq_len; j++) {
                if (causal && j > i) {
                    scores[i * seq_len + j] = -INFINITY;
                    continue;
                }

                const float* k_j = k_head + j * head_dim;
                float sum = 0.0f;
                for (size_t d = 0; d < head_dim; d++) {
                    sum += q_i[d] * k_j[d];
                }
                scores[i * seq_len + j] = sum / sqrtf(static_cast<float>(head_dim));
            }
        }

        // Softmax
        for (size_t i = 0; i < seq_len; i++) {
            float max_val = scores[i * seq_len];
            for (size_t j = 1; j < seq_len; j++) {
                if (scores[i * seq_len + j] > max_val) {
                    max_val = scores[i * seq_len + j];
                }
            }

            float sum = 0.0f;
            for (size_t j = 0; j < seq_len; j++) {
                if (std::isfinite(scores[i * seq_len + j])) {
                    scores[i * seq_len + j] = expf(scores[i * seq_len + j] - max_val);
                    sum += scores[i * seq_len + j];
                }
            }

            for (size_t j = 0; j < seq_len; j++) {
                if (sum > 0.0f) {
                    scores[i * seq_len + j] /= sum;
                }
            }
        }

        // Output
        for (size_t i = 0; i < seq_len; i++) {
            float* o_i = o_head + i * head_dim;

            for (size_t d = 0; d < head_dim; d++) {
                float sum = 0.0f;
                for (size_t j = 0; j < seq_len; j++) {
                    sum += scores[i * seq_len + j] * v_head[j * head_dim + d];
                }
                o_i[d] = sum;
            }
        }
    }
}

} // namespace nova