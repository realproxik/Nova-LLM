// core/nova_speculative.cpp
#include "s.h"
#include <random>
#include <algorithm>
#include <cmath>

namespace nova {

SpeculativeDecoder::SpeculativeDecoder()
    : draft_len_(5), max_tokens_(2048), temperature_(0.8f), top_p_(0.9f), top_k_(50) {}

SpeculativeDecoder::~SpeculativeDecoder() {}

void SpeculativeDecoder::init(
    GenerateFunc draft_model,
    GenerateFunc target_model,
    VerifyFunc verify_func,
    int draft_len,
    int max_tokens
) {
    draft_model_ = draft_model;
    target_model_ = target_model;
    verify_func_ = verify_func;
    draft_len_ = draft_len;
    max_tokens_ = max_tokens;
}

std::vector<int> SpeculativeDecoder::generate(
    const std::vector<int>& prompt,
    int max_new_tokens,
    float temperature,
    float top_p,
    int top_k
) {
    temperature_ = temperature;
    top_p_ = top_p;
    top_k_ = top_k;

    std::vector<int> result = prompt;

    int generated = 0;
    while (generated < max_new_tokens) {
        // Draft generation
        std::vector<int> draft;
        int draft_tokens_count = std::min(draft_len_, max_new_tokens - generated);

        // Generate draft from draft model
        draft = draft_model_(result, draft_tokens_count);

        if (draft.empty()) break;

        // Verify draft with target model
        std::vector<int> accepted;
        bool verify_result = verify_draft(result, draft, accepted);

        // Append accepted tokens
        result.insert(result.end(), accepted.begin(), accepted.end());
        generated += accepted.size();

        if (accepted.size() < draft.size()) {
            // Rejected at some point - continue
            continue;
        }

        // All accepted - generate next token from target
        std::vector<int> next = target_model_(result, 1);
        if (!next.empty()) {
            result.push_back(next[0]);
            generated++;
        }
    }

    return result;
}

bool SpeculativeDecoder::verify_draft(
    const std::vector<int>& prompt,
    const std::vector<int>& draft,
    std::vector<int>& accepted
) {
    // Get target model logits for the draft tokens
    // This is a simplified verification

    std::vector<int> full_prompt = prompt;
    for (size_t i = 0; i < draft.size(); i++) {
        // Verify each draft token
        float accept_prob = 0.95f; // Placeholder

        // Sample acceptance
        std::random_device rd;
        std::mt19937 gen(rd());
        std::uniform_real_distribution<float> dist(0.0f, 1.0f);

        if (dist(gen) < accept_prob) {
            accepted.push_back(draft[i]);
        } else {
            // Resample with target model
            std::vector<int> resampled = target_model_(full_prompt, 1);
            if (!resampled.empty()) {
                accepted.push_back(resampled[0]);
            }
            return false;
        }

        full_prompt.push_back(draft[i]);
    }

    return true;
}

float SpeculativeDecoder::compute_acceptance_prob(
    float target_prob,
    float draft_prob
) {
    return std::min(1.0f, target_prob / (draft_prob + 1e-7f));
}

int SpeculativeDecoder::sample_token(const std::vector<float>& probs) {
    float total = 0.0f;
    for (float p : probs) total += p;

    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_real_distribution<float> dist(0.0f, 1.0f);

    float r = dist(gen) * total;
    float cumsum = 0.0f;
    for (size_t i = 0; i < probs.size(); i++) {
        cumsum += probs[i];
        if (r < cumsum) {
            return static_cast<int>(i);
        }
    }

    return 0;
}

void SpeculativeDecoder::reset() {
    draft_tokens_.clear();
    draft_probs_.clear();
    accepted_tokens_.clear();
}

} // namespace nova