// tokenizer/nova_bpe.cpp
#include "nova_bpe.h"
#include <fstream>
#include <sstream>
#include <algorithm>
#include <cmath>

namespace nova {

BPETokenizer::BPETokenizer()
    : bos_id_(-1), eos_id_(-1), pad_id_(-1), unk_id_(-1) {}

BPETokenizer::~BPETokenizer() {}

void BPETokenizer::init(const std::string& vocab_path, const std::string& merges_path) {
    load(vocab_path);
    // Load merges if provided
}

void BPETokenizer::train(const std::vector<std::string>& texts, size_t vocab_size) {
    build_vocab(texts);

    std::vector<std::vector<int>> tokenized;
    for (const auto& text : texts) {
        auto words = get_words(text);
        for (const auto& word : words) {
            tokenized.push_back(word_to_tokens(word));
        }
    }

    while (vocab_.size() < vocab_size) {
        compute_pair_frequencies(tokenized);

        if (merges_.empty()) break;

        // Find most frequent pair
        Pair best_pair;
        int best_freq = 0;

        for (const auto& [pair, _] : merges_) {
            int freq = 0;
            for (const auto& tokens : tokenized) {
                for (size_t i = 0; i < tokens.size() - 1; i++) {
                    if (tokens[i] == pair.first && tokens[i + 1] == pair.second) {
                        freq++;
                    }
                }
            }
            if (freq > best_freq) {
                best_freq = freq;
                best_pair = pair;
            }
        }

        if (best_freq == 0) break;

        int new_id = vocab_.size();
        std::string new_token = vocab_[best_pair.first] + vocab_[best_pair.second];
        vocab_[new_id] = new_token;
        reverse_vocab_[new_token] = new_id;

        add_merge_rule(best_pair.first, best_pair.second, new_id);

        // Update tokenized sequences
        for (auto& tokens : tokenized) {
            std::vector<int> new_tokens;
            for (size_t i = 0; i < tokens.size(); i++) {
                if (i < tokens.size() - 1 &&
                    tokens[i] == best_pair.first &&
                    tokens[i + 1] == best_pair.second) {
                    new_tokens.push_back(new_id);
                    i++;
                } else {
                    new_tokens.push_back(tokens[i]);
                }
            }
            tokens = std::move(new_tokens);
        }

        merges_[best_pair] = best_freq;
    }
}

void BPETokenizer::build_vocab(const std::vector<std::string>& texts) {
    std::unordered_set<int> unique_tokens;

    for (const auto& text : texts) {
        auto words = get_words(text);
        for (const auto& word : words) {
            auto tokens = word_to_tokens(word);
            for (int token : tokens) {
                unique_tokens.insert(token);
            }
        }
    }

    vocab_.clear();
    reverse_vocab_.clear();

    int id = 0;
    for (int token : unique_tokens) {
        if (token >= 256) break; // Only basic tokens
        std::string str = "t_" + std::to_string(token);
        vocab_[id] = str;
        reverse_vocab_[str] = id;
        id++;
    }
}

std::vector<std::string> BPETokenizer::get_words(const std::string& text) const {
    std::vector<std::string> words;
    std::string current;

    for (char c : text) {
        if (c == ' ' || c == '\n' || c == '\t') {
            if (!current.empty()) {
                words.push_back(current);
                current.clear();
            }
        } else {
            current += c;
        }
    }

    if (!current.empty()) {
        words.push_back(current);
    }

    return words;
}

std::vector<int> BPETokenizer::word_to_tokens(const std::string& word) const {
    std::vector<int> tokens;
    for (char c : word) {
        tokens.push_back(static_cast<int>(c));
    }
    return tokens;
}

std::string BPETokenizer::tokens_to_word(const std::vector<int>& tokens) const {
    std::string result;
    for (int token : tokens) {
        auto it = vocab_.find(token);
        if (it != vocab_.end()) {
            result += it->second;
        } else {
            result += "?";
        }
    }
    return result;
}

std::vector<int> BPETokenizer::bpe_merge(const std::vector<int>& tokens) const {
    std::vector<int> result = tokens;
    bool merged = true;

    while (merged) {
        merged = false;
        int best_a = -1, best_b = -1, best_id = -1;
        int best_count = 0;

        for (size_t i = 0; i < result.size() - 1; i++) {
            int a = result[i];
            int b = result[i + 1];

            auto it = merge_rules_.find(a);
            if (it != merge_rules_.end()) {
                if (it->second.find(b) != it->second.end()) {
                    // This is a valid merge
                    if (merges_.find({a, b}) != merges_.end()) {
                        // Find the merge ID
                        for (const auto& [pair, id] : merges_) {
                            if (pair.first == a && pair.second == b) {
                                best_a = a;
                                best_b = b;
                                best_id = id;
                                break;
                            }
                        }
                        merged = true;
                        break;
                    }
                }
            }
        }

        if (merged && best_a != -1 && best_b != -1) {
            std::vector<int> new_result;
            for (size_t i = 0; i < result.size(); i++) {
                if (i < result.size() - 1 &&
                    result[i] == best_a &&
                    result[i + 1] == best_b) {
                    new_result.push_back(best_id);
                    i++;
                } else {
                    new_result.push_back(result[i]);
                }
            }
            result = std::move(new_result);
        }
    }

    return result;
}

void BPETokenizer::add_merge_rule(int a, int b, int new_id) {
    merge_rules_[a].insert(b);
}

void BPETokenizer::add_special_token(const std::string& token) {
    int id = vocab_.size();
    vocab_[id] = token;
    reverse_vocab_[token] = id;
}

void BPETokenizer::set_special_tokens(const std::string& bos, const std::string& eos,
                                      const std::string& pad, const std::string& unk) {
    add_special_token(bos);
    add_special_token(eos);
    add_special_token(pad);
    add_special_token(unk);

    bos_id_ = reverse_vocab_[bos];
    eos_id_ = reverse_vocab_[eos];
    pad_id_ = reverse_vocab_[pad];
    unk_id_ = reverse_vocab_[unk];
}

std::vector<int> BPETokenizer::encode(const std::string& text) const {
    std::vector<int> tokens;

    auto words = get_words(text);
    for (const auto& word : words) {
        auto word_tokens = word_to_tokens(word);
        auto merged = bpe_merge(word_tokens);
        tokens.insert(tokens.end(), merged.begin(), merged.end());
    }

    return tokens;
}

std::string BPETokenizer::decode(const std::vector<int>& tokens) const {
    std::string result;

    for (int token : tokens) {
        auto it = vocab_.find(token);
        if (it != vocab_.end()) {
            result += it->second;
        } else {
            result += "?";
        }
    }

    return result;
}

void BPETokenizer::save(const std::string& path) const {
    std::ofstream file(path);
    if (!file.is_open()) return;

    // Save vocabulary
    for (const auto& [id, token] : vocab_) {
        file << id << " " << token << "\n";
    }

    file.close();
}

void BPETokenizer::load(const std::string& path) {
    std::ifstream file(path);
    if (!file.is_open()) return;

    vocab_.clear();
    reverse_vocab_.clear();

    std::string line;
    while (std::getline(file, line)) {
        std::istringstream iss(line);
        int id;
        std::string token;
        iss >> id >> token;
        vocab_[id] = token;
        reverse_vocab_[token] = id;
    }

    file.close();
}

} // namespace nova